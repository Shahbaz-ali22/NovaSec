{% extends "base.html.j2" %}

{% block content %}
<header>
    <h1>Technical Security Report</h1>
    <p>Target: <strong>{{ report.metadata.target }}</strong> | Generated at: {{ report.generated_at | datetime_format }}</p>
</header>

<div class="card">
    <h2>Detailed Technical Findings</h2>
    <p>This section outlines all findings identified during the security assessment with their technical evidence.</p>
</div>

{% for finding in findings %}
<div class="card" style="border-left: 5px solid {{ finding.severity.value | severity_color }};">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
        <h3 style="margin: 0;">{{ finding.title }}</h3>
        <span class="severity-badge severity-{{ finding.severity.value }}">{{ finding.severity.value }}</span>
    </div>
    
    <p><strong>Target:</strong> <code>{{ finding.target }}</code></p>
    <p><strong>Description:</strong> {{ finding.description }}</p>
    
    {% if finding.evidence %}
    <h4>Evidence Output</h4>
    {% for ev in finding.evidence %}
    <pre>{{ ev.data }}</pre>
    {% endfor %}
    {% endif %}
</div>
{% endfor %}
{% endblock %}
